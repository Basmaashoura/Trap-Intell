{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=trapintel;Username=trapintel_user;Password=TrapIntel_Secure_2024!;Include Error Detail=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ],
    "Properties": {
      "Application": "Trap-Intel.Api"
    }
  },
  "EmailSettings": {
    "SmtpHost": "mailpit",
    "SmtpPort": 1025,
    "SmtpUsername": "",
    "SmtpPassword": "",
    "EnableSsl": false,
    "SenderEmail": "noreply@trapintel.local",
    "SenderName": "Trap-Intel System",
    "FrontendBaseUrl": "http://localhost:3000",
    "EmailVerificationPath": "/verify-email",
    "PasswordResetPath": "/reset-password",
    "OrganizationInvitationPath": "/invitations/accept"
  },
  "Cloudinary": {
    "CloudName": "",
    "ApiKey": "",
    "ApiSecret": "",
    "UserMediaFolder": "trap-intel/docker/users",
    "OrganizationMediaFolder": "trap-intel/docker/organizations",
    "MaxFileSizeBytes": 5242880,
    "MaxParallelUploads": 4
  },
  "PaymentGateway": {
    "Provider": "Stripe",
    "StripeSecretKey": "",
    "StripeApiBaseUrl": "https://api.stripe.com/v1/"
  },
  "Billing": {
    "OverdueProcessing": {
      "RunOnStartup": true
    }
  },
  "Notifications": {
    "PlanLifecycle": {
      "IncludeOrganizationAdmins": true
    }
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": "",
      "Protocol": "Grpc"
    }
  },
  "AllowedHosts": "*"
}
