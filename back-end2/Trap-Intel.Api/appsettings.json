{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=trapintel;Username=trapintel_user;Password=YOUR_PASSWORD_HERE"
  },
  "Authentication": {
    "Jwt": {
      "SecretKey": "YOUR-SUPER-SECRET-KEY-AT-LEAST-32-CHARACTERS-LONG-FOR-SECURITY",
      "Issuer": "trap-intel",
      "Audience": "trap-intel-api",
      "AccessTokenExpirationMinutes": 15
    },
    "RefreshToken": {
      "TokenLifetimeDays": 7,
      "RememberMeTokenLifetimeDays": 30,
      "MaxActiveSessions": 5,
      "RevokeOldestOnMaxExceeded": true,
      "ExpiredTokenRetentionDays": 30,
      "EnableReuseDetection": true,
      "ConcurrentUseGracePeriodSeconds": 10
    },
    "Lockout": {
      "MaxFailedAttempts": 5,
      "LockoutDurationMinutes": 15,
      "EnableLockout": true,
      "LockoutSuperAdmin": false,
      "ProgressiveLockoutMultiplier": 2.0,
      "MaxLockoutDurationMinutes": 1440
    }
  },
  "EmailSettings": {
    "SmtpHost": "smtp.example.com",
    "SmtpPort": 587,
    "SmtpUsername": "",
    "SmtpPassword": "",
    "EnableSsl": true,
    "SenderEmail": "noreply@trapintel.com",
    "SenderName": "Trap-Intel",
    "FrontendBaseUrl": "https://app.trapintel.com",
    "EmailVerificationPath": "/verify-email",
    "PasswordResetPath": "/reset-password",
    "OrganizationInvitationPath": "/invitations/accept"
  },
  "Cloudinary": {
    "CloudName": "",
    "ApiKey": "",
    "ApiSecret": "",
    "UserMediaFolder": "trap-intel/users",
    "OrganizationMediaFolder": "trap-intel/organizations",
    "MaxFileSizeBytes": 5242880,
    "MaxParallelUploads": 4
  },
  "PaymentGateway": {
    "Provider": "Stripe",
    "StripeSecretKey": "",
    "StripeApiBaseUrl": "https://api.stripe.com/v1/"
  },
  "Billing": {
    "OverdueProcessing": {
      "RunOnStartup": false
    }
  },
  "Notifications": {
    "PlanLifecycle": {
      "IncludeOrganizationAdmins": true
    }
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": "",
      "Protocol": "Grpc"
    }
  },
  "EmailVerificationSettings": {
    "TokenExpirationHours": 24,
    "RequireEmailVerification": true
  },
  "PasswordResetSettings": {
    "TokenExpirationMinutes": 60,
    "MaxRequestsPerWindow": 3,
    "RateLimitWindowMinutes": 60
  },
  "TokenCleanupSettings": {
    "CleanupIntervalHours": 6,
    "RetentionDays": 7
  },
  "TwoFactorSettings": {
    "Issuer": "Trap-Intel",
    "TotpDigits": 6,
    "TotpTimeStepSeconds": 30,
    "TotpTimeTolerance": 1,
    "BackupCodeCount": 10,
    "MaxVerificationAttempts": 5,
    "VerificationLockoutMinutes": 15,
    "RequireRecentVerificationForSensitiveOps": true,
    "RecentVerificationWindowMinutes": 15,
    "SendNotificationOnStatusChange": true,
    "AlertOnLowBackupCodes": true,
    "LowBackupCodesThreshold": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
